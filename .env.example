# GrantLayer MVP — Example environment variables
#
# IMPORTANT: All values below are examples / placeholders only.
# Do NOT use real secrets, private hostnames, or customer data here.
# Copy this file to .env and replace placeholder values with your own.
# .env is git-ignored; .env.example is tracked and must never contain real secrets.
#
# Developer Preview — local evaluation only. Not a production SaaS.


# ── Core database (choose ONE) ──────────────────────
# Legacy plain path (still supported)
GRANTLAYER_DB=data/grantlayer.db

# New SQLite database URL (takes precedence over GRANTLAYER_DB)
# GRANTLAYER_DATABASE_URL=sqlite:///data/grantlayer.db
# GRANTLAYER_DATABASE_URL=sqlite:///:memory:

# PostgreSQL database URL (takes precedence over SQLite)
# GRANTLAYER_DATABASE_URL=postgres://grantlayer:password@localhost:5432/grantlayer

# PostgreSQL Docker Compose password (used by docker-compose.postgres.yml)
# GRANTLAYER_POSTGRES_PASSWORD=change_me_in_production

# ── Runtime mode ────────────────────────────────────
# Valid values: local, demo, test, staging, production.
# ("development" is NOT a valid value.)
# docker-compose.yml defaults to local (evaluation quickstart).
# A bare `python3 -m backend` with this variable unset defaults to
# production, which additionally requires Redis, a strong admin token and
# GRANTLAYER_UNSUBSCRIBE_SECRET (see DEPLOYMENT.md).
# GRANTLAYER_RUNTIME_MODE=local

# ── Runtime ─────────────────────────────────────────
GRANTLAYER_HOST=127.0.0.1
GRANTLAYER_PORT=8765

# ── Logging ─────────────────────────────────────────
GRANTLAYER_LOG_LEVEL=INFO

# ── Health ──────────────────────────────────────────
GRANTLAYER_HEALTH_PROBE_DB_TIMEOUT_MS=2000

# ── PostgreSQL connection retry ─────────────────────
# GRANTLAYER_DB_RETRY_MAX=5
# GRANTLAYER_DB_RETRY_DELAY=1.0

# ── PostgreSQL connection pool ──────────────────────
# GRANTLAYER_DB_POOL_MIN=2
# GRANTLAYER_DB_POOL_MAX=10

# ── Hardening (production) ──────────────────────────
GRANTLAYER_REQUIRE_ADMIN_TOKEN=true
GRANTLAYER_REQUIRE_CHALLENGE=true
GRANTLAYER_ENABLE_DEMO_ENDPOINTS=false

# ── Admin token (required when REQUIRE_ADMIN_TOKEN=true)
GRANTLAYER_ADMIN_TOKEN=change-me-in-production

# ── Unsubscribe token secret (required in production-like modes)
# HMAC secret protecting signed unsubscribe tokens. Generate with:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
# GRANTLAYER_UNSUBSCRIBE_SECRET=

# ── Operator model ──────────────────────────────────
GRANTLAYER_ENABLE_OPERATOR_MODEL=true
GRANTLAYER_BOOTSTRAP_OPERATOR_TOKEN=
GRANTLAYER_BOOTSTRAP_OPERATOR_ID=bootstrap-admin
GRANTLAYER_BOOTSTRAP_OPERATOR_NAME=Bootstrap Admin
GRANTLAYER_BOOTSTRAP_OPERATOR_ROLE=owner

# ── JWT Auth (RS256 — default) ───────────────────────
# RS256 is the default algorithm. Generate a key pair and base64-encode the PEM files:
#   openssl genrsa -out private.pem 2048
#   openssl rsa -in private.pem -pubout -out public.pem
#   export GRANTLAYER_JWT_PRIVATE_KEY=$(base64 -w0 private.pem)
#   export GRANTLAYER_JWT_PUBLIC_KEY=$(base64 -w0 public.pem)
# Paste the output of the export commands into .env (without the "export " prefix).
GRANTLAYER_JWT_PRIVATE_KEY=
GRANTLAYER_JWT_PUBLIC_KEY=

# ── JWT Auth (HS256 — legacy) ────────────────────────
# Symmetric fallback. Only use when RS256 keys are not set.
# Set GRANTLAYER_JWT_ALGORITHM=HS256 and supply a random secret:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
# GRANTLAYER_JWT_ALGORITHM=HS256
# GRANTLAYER_JWT_SECRET=

# JWT token TTL in hours (default: 1)
# GRANTLAYER_JWT_TTL_HOURS=1
