  "nonGoals": [
    "Production authentication (OAuth, JWT, SSO, HSM-backed key management)",
    "Production credential management (HSM, vault integration, credential rotation)",
    "Deployment hardening (containers, load balancing, TLS termination, orchestration)",
    "Observability (metrics, logging pipelines, alerting, tracing)",
    "Backup / restore (automated backup, point-in-time recovery, disaster runbooks)",
    "SDKs (Python, JavaScript, Go client libraries)",
    "Blockchain / wallet / payment integrations",
    "Legal or compliance certification",
    "Dashboard / UI productization",
    "Multi-tenant SaaS architecture (tenant isolation, subscription billing, SaaS onboarding)"
  ],
  "pilotSuccessCriteria": [
    "Partner understands the core flow (request → approval → grant → execution → evidence → audit)",
    "Partner can follow the minimal walkthrough and trace stable identifiers through every stage",
    "Partner can inspect the demo fixture and static examples and understand the data relationships",
    "Partner can identify where their system would integrate",
    "Partner can list missing production requirements and differentiate them from Integration-Ready v0 scope",
    "No P0/P1 integration blockers are found in the handoff artifacts"
  ],
  "recommendedNextDecisions": [
    "Choose first pilot target / partner profile",
    "Define pilot environment expectations (local vs hosted demo instance)",
    "Decide whether to build a small demo runner or API smoke script",
    "Decide production-hardening priority (OAuth/JWT, credential management, observability, backup/restore, multi-tenancy)",
    "Decide whether SDK / client examples are needed"
  ],
  "productionReady": false,
