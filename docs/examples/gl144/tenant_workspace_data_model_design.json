  "proposed_entities": {
    "tenants": {
      "purpose": "top-level customer boundary",
      "fields": [
        "id",
        "slug",
        "name",
        "display_name",
        "status",
        "created_at",
        "updated_at"
      ]
    },
    "workspaces": {
      "purpose": "scoped operating context within a tenant",
      "fields": [
        "id",
        "tenant_id",
        "slug",
        "name",
        "display_name",
        "status",
        "created_at",
        "updated_at"
      ]
    },
    "tenant_memberships": {
      "purpose": "associate operators with tenants",
      "fields": [
        "id",
        "tenant_id",
        "operator_id",
        "role",
        "status",
        "created_at",
        "updated_at"
      ]
    },
    "workspace_memberships": {
      "purpose": "associate operators with workspaces",
      "fields": [
        "id",
        "workspace_id",
        "operator_id",
        "role",
        "status",
        "created_at",
        "updated_at"
      ]
    },
    "operator_scope": {
      "purpose": "define workspace access scope for operators within a tenant",
      "fields": [
        "operator_id",
        "tenant_id",
        "workspace_id",
        "scope_type",
        "created_at"
      ]
    }
  },
  "relationship_model": {
    "tenant_to_workspace": "1:N (Tenant has many Workspaces)",
    "workspace_to_tenant": "N:1 (Workspace belongs to one Tenant)",
    "operator_to_tenant": "N:M via tenant_memberships",
    "operator_to_workspace": "N:M via workspace_memberships",
    "grant_request_ownership": "belongs to one workspace",
    "grant_execution_ownership": "belongs to one workspace",
    "evidence_ownership": "belongs to one workspace",
    "audit_event_context": "carries tenant/workspace context",
    "provenance_event_context": "carries tenant/workspace context"
  },
  "isolation_rules": [
    "customer-owned resources must be tenant/workspace scoped",
    "no cross-tenant reads by default",
    "no cross-workspace access without explicit scope",
    "admin legacy mode is not SaaS tenant isolation",
    "background/system operations must have explicit system scope"
  ],
  "auth_permission_implications": [
    "operator token lookup remains secure",
    "future permissions must include tenant/workspace scope",
    "explicit deny-by-default for missing scope",
