{
  "gl079_secret_source_boundary_examples": {
    "description": "Safe example outputs for the GL-079 secret source boundary helpers. No raw secret values are included anywhere in this file.",
    "examples": [
      {
        "example": "optional_missing_secret",
        "name": "MY_SECRET",
        "env": {},
        "read_optional_secret_result": null,
        "describe_secret_source_result": {
          "name": "MY_SECRET",
          "source": "environment",
          "present": false,
          "valuePreview": null
        }
      },
      {
        "example": "required_missing_secret_safe_error",
        "name": "REQUIRED_SECRET",
        "env": {},
        "read_required_secret_error": "SecretConfigurationError: required secret 'REQUIRED_SECRET' is missing or empty",
        "describe_secret_source_result": {
          "name": "REQUIRED_SECRET",
          "source": "environment",
          "present": false,
          "valuePreview": null
        }
      },
      {
        "example": "present_secret_redacted_in_describe_output",
        "name": "PRESENT_SECRET",
        "env": {"PRESENT_SECRET": "<PLACEHOLDER_SECRET_VALUE_REDACTED>"},
        "read_optional_secret_result": "<PLACEHOLDER_SECRET_VALUE_REDACTED>",
        "describe_secret_source_result": {
          "name": "PRESENT_SECRET",
          "source": "environment",
          "present": true,
          "valuePreview": "[REDACTED]"
        }
      },
      {
        "example": "validation_summary_with_names_only",
        "names": ["SECRET_A", "SECRET_B", "SECRET_C"],
        "env": {"SECRET_A": "<VALUE_A>", "SECRET_B": "<VALUE_B>"},
        "validate_required_secrets_result": {
          "valid": false,
          "missing": ["SECRET_C"],
          "present": ["SECRET_A", "SECRET_B"],
          "source": "environment"
        }
      },
      {
        "example": "redact_secret_value_behavior",
        "inputs": [
          {"value": null, "output": null},
          {"value": 42, "output": 42},
          {"value": true, "output": true},
          {"value": "some-credential-string", "output": "[REDACTED]"},
          {"value": "", "output": ""}
        ]
      }
    ]
  }
}
