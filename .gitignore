# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
.venv/
venv/
env/

# SQLite — never commit demo data
data/*.db
data/*.db-wal
data/*.db-shm
backend/data/*.db
backend/data/*.db-wal
backend/data/*.db-shm

# Key / secret / certificate hygiene (GL-136)
# Signing keyring (generated public-key material, env-specific)
data/keyring/
backend/data/keyring/
*.pem
*.key
*.p8
*.p12
*.crt
*.cert
*.csr
.env
.env.*
!.env.example
# Ignore ALL secret contents; track ONLY docs + an empty .gitkeep so the dir
# exists on a fresh clone. The actual secret data files (blockfrost_project_id,
# cardano_signing_key) are NEVER tracked — an operator creates them locally
# before `docker compose up`. See secrets/README.md.
secrets/*
!secrets/README.md
!secrets/.gitkeep
private/
keys/
certs/
!nginx/certs/
!nginx/certs/.gitkeep

# OS
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/
*.swp
*.swo

# Local Claude/OpenCode session files
.claude/

# Node
node_modules/

# Test artifacts
.pytest_cache/
.coverage
.coverage.*
htmlcov/

# Website design workspace import artefacts (not for public repo)
docs/website_design_workspace_import_report*.md
docs/website_design_workspace_import_dirty_stop*.md
docs/website-design-workspace-import-report*.md
website-design/

